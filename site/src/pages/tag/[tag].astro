---
import { readFileSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeedHeader from "../../components/FeedHeader.astro";

export function getStaticPaths() {
  const indexPath = resolve(process.cwd(), "../rendered/index.json");
  const index = JSON.parse(readFileSync(indexPath, "utf-8"));

  const tags = new Set<string>();
  for (const node of index) {
    for (const tag of node.tags ?? []) {
      tags.add(tag);
    }
  }

  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const INDEX_PATH = resolve(process.cwd(), "../rendered/index.json");
const index = JSON.parse(readFileSync(INDEX_PATH, "utf-8"));

const EPOCH = "1970-01-01T00:00:00Z";

const filtered = index.filter((node: { tags?: string[] }) =>
  node.tags?.includes(tag),
);

// Sort by last_modified descending; epoch entries sort to the bottom
const sorted = [...filtered].sort((a, b) => {
  if (a.last_modified === EPOCH && b.last_modified !== EPOCH) return 1;
  if (b.last_modified === EPOCH && a.last_modified !== EPOCH) return -1;
  return b.last_modified.localeCompare(a.last_modified);
});

function formatDate(iso: string): string {
  if (iso === EPOCH) return "";
  return iso.slice(0, 10);
}
---

<BaseLayout title={`addisonbeck.com — ${tag}`}>
  <FeedHeader tag={tag} />
  <nav class="breadcrumb">
    <a href="/">addisonbeck.com</a> / {tag}
  </nav>
  <main id="main">
    <ul class="feed">
      {
        sorted.map((node) => (
          <li class="feed-item" data-slug={node.slug}>
            <div class="feed-item-header">
              <a href={`/${node.slug}`}>{node.title}</a>
              {formatDate(node.last_modified) && (
                <time datetime={node.last_modified}>
                  {formatDate(node.last_modified)}
                </time>
              )}
            </div>
            {node.preview && <p class="feed-item-preview">{node.preview}</p>}
            {node.tags.length > 0 && (
              <ul class="feed-item-tags" aria-label="tags">
                {node.tags.map((t: string) => (
                  <li data-tag={t}>
                    <a href={`/tag/${t}`}>{t}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
    <p id="feed-no-results" hidden>No results.</p>
  </main>
</BaseLayout>
