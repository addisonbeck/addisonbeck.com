---
import { readFileSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../layouts/BaseLayout.astro";

const INDEX_PATH = resolve(process.cwd(), "../rendered/index.json");
const index = JSON.parse(readFileSync(INDEX_PATH, "utf-8"));

const EPOCH = "1970-01-01T00:00:00Z";

// Sort by last_modified descending; epoch entries sort to the bottom
const sorted = [...index].sort((a, b) => {
  if (a.last_modified === EPOCH && b.last_modified !== EPOCH) return 1;
  if (b.last_modified === EPOCH && a.last_modified !== EPOCH) return -1;
  return b.last_modified.localeCompare(a.last_modified);
});

function formatDate(iso: string): string {
  if (iso === EPOCH) return "";
  // Format: "YYYY-MM-DD" (date portion only)
  return iso.slice(0, 10);
}
---

<BaseLayout title="addisonbeck.com">
  <header>
    <h1>addisonbeck.com</h1>
    <nav class="header-icons">
      <a href="/search" aria-label="Search">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          style="display: block;"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
      <span class="divider" aria-hidden="true">|</span>
      <a href="/rss-feeds" aria-label="RSS Feeds">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="currentColor"
          aria-hidden="true"
          style="display: block;"
        >
          <circle cx="6.18" cy="17.82" r="2.18"></circle>
          <path
            d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"
          ></path>
        </svg>
      </a>
    </nav>
  </header>
  <main id="main">
    <ul class="feed">
      {
        sorted.map((node) => (
          <li class="feed-item">
            <a href={`/${node.slug}`}>{node.title}</a>
            {formatDate(node.last_modified) && (
              <time datetime={node.last_modified}>
                {formatDate(node.last_modified)}
              </time>
            )}
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  .header-icons {
    margin-left: auto;
    display: flex;
    align-items: center;
    align-self: center;
    gap: 0.5rem;
  }
  .divider {
    color: var(--fg4);
    user-select: none;
  }
</style>
