---
import BacklinkPanel from '../components/BacklinkPanel.svelte';

interface Props {
  title: string;
  backlinks: Array<{ id: string; title: string; slug: string }>;
}

const { title, backlinks } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <nav data-pagefind-ignore>
      <a href="/">← Home</a>
    </nav>
    <main>
      <h1 class="page-title">{title}</h1>
      <article data-pagefind-body>
        <slot />
      </article>
      <aside data-pagefind-ignore>
        <BacklinkPanel backlinks={backlinks} client:idle />
      </aside>
    </main>
  </body>
</html>
