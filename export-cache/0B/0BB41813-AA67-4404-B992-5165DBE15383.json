nous and pasty. Place in an oven set to 350 and stir\n   occasionally for about 4 hours. The roux should be chocolate brown\n   when done, with no scrotching or black flakes. You can do this on the\n   stove for about an hour, whisking constantly, for the same result -\n   but there is a higher risk of burning. The slow oven cook is much\n   more consistent.\n"]],["item",{"bullet":"2. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":1576,"post-affiliated":1576,"contents-begin":1579,"contents-end":1706,"end":1706,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":1579,"post-affiliated":1579,"contents-begin":1579,"contents-end":1706,"end":1706,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"In a seperate pot over medium-high heat cook the sausage for about 6\n   minutes until brown. Transfer to a bowl and set aside.\n"]],["item",{"bullet":"3. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":1706,"post-affiliated":1706,"contents-begin":1709,"contents-end":1959,"end":1959,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":1709,"post-affiliated":1709,"contents-begin":1709,"contents-end":1959,"end":1959,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"Add onion, bell pepper, and celery and season lightly with salt. Add\n   all of the roux and cook over medium-high heat, stirring and\n   scraping, until softened, about 10 minutes. Lower heat to medium if\n   any of the ingredients threaten to scorch.\n"]],["item",{"bullet":"4. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":1959,"post-affiliated":1959,"contents-begin":1962,"contents-end":2021,"end":2021,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":1962,"post-affiliated":1962,"contents-begin":1962,"contents-end":2021,"end":2021,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"Stir in garlic and season, stirring, for 2 minutes longer.\n"]],["item",{"bullet":"5. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":2021,"post-affiliated":2021,"contents-begin":2024,"contents-end":2155,"end":2155,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":2024,"post-affiliated":2024,"contents-begin":2024,"contents-end":2155,"end":2155,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"Add stock, bay leaves, and thyme. Bring to a gentle simmer, then\n   allow to cook uncovered, stirring occasionally, for 1.5 hours.\n"]],["item",{"bullet":"6. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":2155,"post-affiliated":2155,"contents-begin":2158,"contents-end":2376,"end":2376,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":2158,"post-affiliated":2158,"contents-begin":2158,"contents-end":2376,"end":2376,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"Add okra, if using, along with sausage and shredded chicken, and\n   gently simmer, uncovered, for 25 minutes longer. Add any shrimp and\n   simmer for 5 more minutes. Skim any fat from the surface as it\n   accumulates.\n"]],["item",{"bullet":"7. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":2376,"post-affiliated":2376,"contents-begin":2379,"contents-end":2537,"end":2537,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},["paragraph",{"begin":2379,"post-affiliated":2379,"contents-begin":2379,"contents-end":2537,"end":2537,"post-blank":0,"secondary":null,"mode":null,"granularity":null,"cached":null,"org-element--cache-sync-key":null,"robust-begin":null,"robust-end":null,"true-level":null,"buffer":null,"deferred":null,"structure":null,"parent":null},"Remove from heat and add filé powder, if using, stirring well to\n   break up any small lumps. Season gumbo with salt. Discard thyme\n   sprigs and bay leaves.\n"]],["item",{"bullet":"8. ","checkbox":null,"counter":null,"pre-blank":0,"tag":null,"begin":2537,"post-affiliated":2537,"contents-begin":2540,"contents-end":2747,"end":2747,"post-blank":0,"secondary":null,"mode":"item","granularity":null,"cached